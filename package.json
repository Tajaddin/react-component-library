{
  "name": "@tajaddin/react-components",
  "version": "0.1.0",
  "description": "Production-grade React component library: Modal, DataTable, FormBuilder, Toast, Dropdown, Pagination, Tabs. TypeScript, accessibility-tested with jest-axe, zero peer deps beyond React.",
  "type": "module",
  "main": "./dist/index.umd.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.umd.cjs",
      "types": "./dist/index.d.ts"
    },
    "./styles.css": "./dist/components.css"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": [
    "*.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "bench:size": "node bench/measure-size.mjs",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.0",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.10.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "jest-axe": "^9.0.0",
    "@types/jest-axe": "^3.5.9",
    "jsdom": "^25.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
    "vite-plugin-dts": "^4.0.0",
    "vitest": "^2.0.0"
  },
  "keywords": [
    "react",
    "components",
    "ui",
    "typescript",
    "accessibility",
    "a11y",
    "modal",
    "datatable",
    "formbuilder"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Tajaddin/react-component-library.git"
  },
  "license": "MIT",
  "author": "Tajaddin Gafarov"
}
